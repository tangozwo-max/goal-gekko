<!-- Gecko AI Chat Panel -->
<button id="gekko-toggle" title="Chat with Gecko" aria-label="Open Gecko career consultant">
  <img src="/images/goal_gekko.gif" alt="" width="26" height="26" style="border-radius:50%;object-fit:contain;">
</button>

<div id="gekko-panel" role="complementary" aria-label="Gecko career consultant">
  <div id="gekko-resize" title="Resize"></div>
  <div id="gekko-hdr" title="Drag to move">
    <div style="display:flex;align-items:center;gap:7px;">
      <img src="/images/goal_gekko.gif" alt="Gecko" width="18" height="18" style="border-radius:50%;object-fit:contain;flex-shrink:0;">
      <span style="font-size:10px;font-weight:600;color:rgba(255,255,255,0.85);letter-spacing:.03em;">Gecko</span>
      <span style="font-size:7.5px;color:rgba(255,255,255,0.3);letter-spacing:.08em;text-transform:uppercase;">Career Strategy</span>
    </div>
    <div style="display:flex;align-items:center;gap:4px;">
      <div id="gekko-tier-wrap" style="display:flex;border:1px solid rgba(255,255,255,0.1);border-radius:5px;overflow:hidden;">
        <button class="tier-btn" data-tier="fast" title="Fast · Haiku">⚡</button>
        <button class="tier-btn active" data-tier="balanced" title="Balanced · Sonnet">⚡⚡</button>
        <button class="tier-btn" data-tier="deep" title="Deep · Opus">⚡⚡⚡</button>
      </div>
      <div style="display:flex;border:1px solid rgba(255,255,255,0.08);border-radius:5px;overflow:hidden;margin-right:2px;">
        <button id="gekko-font-minus" title="Smaller text" style="background:transparent;border:none;color:rgba(255,255,255,0.35);font-size:9px;padding:2px 6px;cursor:pointer;font-family:inherit;line-height:1;">A−</button>
        <button id="gekko-font-plus"  title="Larger text"  style="background:transparent;border:none;color:rgba(255,255,255,0.35);font-size:9px;padding:2px 6px;cursor:pointer;font-family:inherit;line-height:1;border-left:1px solid rgba(255,255,255,0.08);">A+</button>
      </div>
      <button id="gekko-archive" title="Zusammenfassen &amp; archivieren" style="display:none;background:none;border:1px solid rgba(0,255,136,0.22);border-radius:4px;color:rgba(0,255,136,0.6);font-size:9px;padding:2px 6px;cursor:pointer;transition:background .15s,color .15s;font-family:inherit;line-height:1;white-space:nowrap;">⊙ Archiv</button>
      <button id="gekko-close" title="Close">✕</button>
    </div>
  </div>

  <div id="gekko-memory-bar" style="display:none;flex-shrink:0;border-bottom:1px solid rgba(0,255,136,0.12);background:rgba(0,255,136,0.03);max-height:120px;overflow-y:auto;"></div>

  <div id="gekko-msgs"></div>

  <div id="gekko-proposals" style="display:none;"></div>

  <div id="gekko-input-wrap">
    <textarea id="gekko-input" placeholder="Ask Gecko about your career…" rows="2"></textarea>
    <button id="gekko-send" title="Send (Enter)">↑</button>
  </div>
</div>

<style is:global>
  #gekko-toggle {
    display: none;
  }

  #gekko-panel {
    position: fixed;
    top: 58px;
    right: 24px;
    width: 340px;
    height: 500px;
    min-width: 240px;
    min-height: 260px;
    max-width: 640px;
    max-height: 88vh;
    z-index: 90;
    background: rgba(4,7,18,0.42);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 10px;
    display: none;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04), 0 0 24px rgba(0,255,136,0.05);
    font-family: Inter, system-ui, sans-serif;
    user-select: none;
  }

  #gekko-resize {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 16px;
    height: 16px;
    cursor: sw-resize;
    z-index: 10;
    border-bottom-left-radius: 9px;
    background: linear-gradient(135deg, transparent 50%, rgba(255,255,255,0.08) 50%);
  }
  #gekko-panel.open { display: flex; }

  #gekko-hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 11px;
    border-bottom: 1px solid rgba(255,255,255,0.10);
    flex-shrink: 0;
    cursor: grab;
    background: rgba(255,255,255,0.04);
    user-select: none;
  }
  #gekko-hdr:active { cursor: grabbing; }

  .tier-btn {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.3);
    font-size: 8px;
    padding: 3px 6px;
    cursor: pointer;
    transition: background .15s, color .15s;
  }
  .tier-btn:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.65); }
  .tier-btn.active { background: rgba(0,255,136,0.1); color: rgba(0,255,136,0.85); }

  #gekko-close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.28);
    font-size: 12px;
    cursor: pointer;
    padding: 3px 5px;
    border-radius: 4px;
    transition: color .15s;
    margin-left: 3px;
    line-height: 1;
  }
  #gekko-close:hover { color: rgba(255,255,255,0.75); }
  #gekko-archive:hover { background: rgba(0,255,136,0.1); color: rgba(0,255,136,0.9); }
  #gekko-archive:disabled { opacity: .38; cursor: default; }
  #gekko-memory-bar::-webkit-scrollbar { width: 3px; }
  #gekko-memory-bar::-webkit-scrollbar-thumb { background: rgba(0,255,136,0.15); border-radius: 3px; }

  #gekko-msgs {
    flex: 1;
    overflow-y: auto;
    padding: 11px 11px 5px;
    display: flex;
    flex-direction: column;
    gap: 9px;
    scroll-behavior: smooth;
    min-height: 0;
    user-select: text;
    --gecko-font: 11px;
  }
  #gekko-msgs::-webkit-scrollbar { width: 3px; }
  #gekko-msgs::-webkit-scrollbar-track { background: transparent; }
  #gekko-msgs::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

  /* User bubble — right-aligned solid blue */
  .msg-user {
    align-self: flex-end;
    background: rgba(30,96,186,0.88);
    border-radius: 8px 8px 2px 8px;
    padding: 5px 9px;
    font-size: var(--gecko-font, 11px);
    color: rgba(255,255,255,0.92);
    max-width: 82%;
    line-height: 1.55;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Gecko bubble — left-aligned dark slate */
  .msg-ai {
    align-self: flex-start;
    max-width: 92%;
  }
  .msg-ai-bubble {
    background: rgba(36,40,56,0.80);
    border-radius: 2px 8px 8px 8px;
    padding: 5px 9px;
    font-size: var(--gecko-font, 11px);
    color: rgba(255,255,255,0.82);
    line-height: 1.65;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .msg-cost {
    margin-top: 2px;
    font-size: 7px;
    color: rgba(255,255,255,0.2);
    letter-spacing: .04em;
    padding-left: 2px;
  }

  .msg-loading {
    align-self: flex-start;
    font-size: var(--gecko-font, 11px);
    color: rgba(255,255,255,0.28);
    padding: 4px 2px;
    letter-spacing: .04em;
  }

  /* Proposal card — shown in tray only */
  .proposal-card {
    border: 1px solid rgba(255,220,80,0.18);
    border-radius: 7px;
    padding: 7px 9px;
    background: rgba(255,220,80,0.03);
    font-size: 8px;
  }
  .proposal-card.accepted { border-color: rgba(0,255,136,0.22); background: rgba(0,255,136,0.03); opacity: .5; }
  .proposal-card.declined { border-color: rgba(255,255,255,0.05); opacity: .28; }
  .proposal-type {
    font-size: 7px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: rgba(255,210,60,0.55);
    margin-bottom: 3px;
  }
  .proposal-desc {
    color: rgba(255,255,255,0.78);
    font-weight: 500;
    margin-bottom: 3px;
    font-size: 8px;
  }
  .proposal-reason {
    color: rgba(255,255,255,0.38);
    font-size: var(--gecko-font, 11px);
    line-height: 1.5;
    margin-bottom: 6px;
  }
  .proposal-btns { display: flex; gap: 5px; }
  .proposal-accept {
    background: rgba(0,255,136,0.1);
    border: 1px solid rgba(0,255,136,0.28);
    color: rgba(0,255,136,0.88);
    border-radius: 4px;
    padding: 3px 9px;
    font-size: 8px;
    cursor: pointer;
    transition: background .15s;
    font-family: inherit;
  }
  .proposal-accept:hover { background: rgba(0,255,136,0.2); }
  .proposal-decline {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.09);
    color: rgba(255,255,255,0.3);
    border-radius: 4px;
    padding: 3px 9px;
    font-size: 8px;
    cursor: pointer;
    transition: background .15s;
    font-family: inherit;
  }
  .proposal-decline:hover { background: rgba(255,255,255,0.04); }
  .proposal-discuss {
    background: transparent;
    border: 1px solid rgba(255,170,60,0.22);
    color: rgba(255,190,80,0.62);
    border-radius: 4px;
    padding: 3px 9px;
    font-size: 8px;
    cursor: pointer;
    transition: background .15s;
    font-family: inherit;
  }
  .proposal-discuss:hover { background: rgba(255,170,60,0.08); }
  .proposal-status {
    font-size: var(--gecko-font, 11px);
    letter-spacing: .05em;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
  }

  #gekko-proposals {
    border-top: 1px solid rgba(255,220,80,0.14);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,220,80,0.02);
    padding: 8px 10px;
    flex-shrink: 0;
    max-height: 200px;
    overflow-y: auto;
  }
  #gekko-proposals::-webkit-scrollbar { width: 3px; }
  #gekko-proposals::-webkit-scrollbar-thumb { background: rgba(255,220,80,0.15); border-radius: 3px; }

  /* Proposal cards in tray */
  .proposal-card {
    font-size: 8px;
  }
  .proposal-card + .proposal-card { margin-top: 4px; }
  .proposal-card.accepted { opacity: .5; }
  .proposal-card.declined { opacity: .28; }
  .proposal-tray-label {
    font-size: 7px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,210,60,0.4);
    margin-bottom: 5px;
    font-weight: 600;
  }

  #gekko-input-wrap {
    border-top: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: flex-end;
    padding: 8px 10px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.01);
  }
  #gekko-input {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 6px 0 0 6px;
    color: rgba(255,255,255,0.82);
    font-size: 12px;
    font-family: inherit;
    padding: 6px 9px;
    resize: none;
    outline: none;
    line-height: 1.5;
    transition: border-color .15s;
    user-select: text;
  }
  #gekko-input:focus { border-color: rgba(29,158,117,0.4); }
  #gekko-input::placeholder { color: rgba(255,255,255,0.22); }
  #gekko-send {
    background: rgba(29,158,117,0.12);
    border: 1px solid rgba(29,158,117,0.28);
    border-left: none;
    border-radius: 0 6px 6px 0;
    color: rgba(29,158,117,0.9);
    font-size: 14px;
    width: 34px;
    align-self: stretch;
    cursor: pointer;
    transition: background .15s;
    font-family: inherit;
    line-height: 1;
  }
  #gekko-send:hover { background: rgba(29,158,117,0.22); }
  #gekko-send:disabled { opacity: .38; cursor: default; }
</style>

<script>
  // v4
  const panel    = document.getElementById('gekko-panel') as HTMLElement | null;
  const toggle   = document.getElementById('gekko-toggle') as HTMLElement | null;
  const closeBtn = document.getElementById('gekko-close') as HTMLElement | null;
  const hdr      = document.getElementById('gekko-hdr') as HTMLElement | null;
  const msgList  = document.getElementById('gekko-msgs') as HTMLElement | null;
  const inputEl  = document.getElementById('gekko-input') as HTMLTextAreaElement | null;
  const sendBtn  = document.getElementById('gekko-send') as HTMLButtonElement | null;

  if (!panel || !toggle || !closeBtn || !hdr || !msgList || !inputEl || !sendBtn) {
    // skip — component not mounted
  } else {
    // Conversation history in Anthropic API format.
    // After a tool_use response, pendingToolResultIds holds the tool_use ids.
    // The next user message will be sent as an array combining tool_results + text,
    // satisfying Anthropic's requirement for tool_result before the next user turn.
    const convMessages: any[] = [];
    let pendingToolResultIds: string[] = [];
    let currentTier = 'balanced';
    let isLoading = false;

    // ── open / close ────────────────────────────────────────────────────────
    toggle.addEventListener('click', () => {
      panel.classList.toggle('open');
      if (panel.classList.contains('open')) scrollBottom();
    });
    closeBtn.addEventListener('click', () => panel.classList.remove('open'));

    // ── tier buttons ─────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.tier-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        currentTier = btn.dataset.tier || 'balanced';
        document.querySelectorAll('.tier-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    // ── font size A+/A- ──────────────────────────────────────────────────────
    let msgFontSize = 11;
    const setMsgFont = (px: number) => {
      msgFontSize = Math.max(8, Math.min(18, px));
      msgList.style.setProperty('--gecko-font', msgFontSize + 'px');
    };
    document.getElementById('gekko-font-plus') ?.addEventListener('click', () => setMsgFont(msgFontSize + 1));
    document.getElementById('gekko-font-minus')?.addEventListener('click', () => setMsgFont(msgFontSize - 1));

    // ── chat memory (localStorage) ───────────────────────────────────────────
    const MEMORY_KEY = 'gekko-chat-memory';
    const archiveBtn  = document.getElementById('gekko-archive') as HTMLButtonElement | null;
    const memoryBar   = document.getElementById('gekko-memory-bar') as HTMLElement | null;
    let currentMemory: { summary: string; savedAt: string } | null = null;
    let memoryInjected = false;

    const loadMemory = () => {
      try { const r = localStorage.getItem(MEMORY_KEY); return r ? JSON.parse(r) : null; } catch { return null; }
    };
    const saveMemory = (summary: string) => {
      const m = { summary, savedAt: new Date().toISOString() };
      localStorage.setItem(MEMORY_KEY, JSON.stringify(m));
      return m;
    };

    const showMemoryBanner = (mem: { summary: string; savedAt: string }) => {
      if (!memoryBar) return;
      const date = new Date(mem.savedAt).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
      memoryBar.style.display = 'block';
      memoryBar.innerHTML = '';
      const header = document.createElement('div');
      header.style.cssText = 'display:flex;justify-content:space-between;align-items:center;padding:5px 10px 3px;position:sticky;top:0;background:rgba(4,7,18,0.9);';
      header.innerHTML = `<span style="font-size:7px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(0,255,136,0.45);">⊙ Was bisher geschah · ${date}</span>`;
      const clearBtn = document.createElement('button');
      clearBtn.textContent = '✕';
      clearBtn.style.cssText = 'background:none;border:none;color:rgba(255,255,255,0.25);font-size:10px;cursor:pointer;padding:0 2px;line-height:1;font-family:inherit;';
      clearBtn.title = 'Zusammenfassung löschen';
      clearBtn.addEventListener('click', () => {
        localStorage.removeItem(MEMORY_KEY);
        memoryBar.style.display = 'none';
        currentMemory = null;
        memoryInjected = false;
      });
      header.appendChild(clearBtn);
      memoryBar.appendChild(header);
      const body = document.createElement('div');
      body.style.cssText = 'padding:4px 10px 8px;font-size:9.5px;color:rgba(255,255,255,0.52);line-height:1.6;white-space:pre-wrap;';
      body.textContent = mem.summary;
      memoryBar.appendChild(body);
    };

    const updateArchiveBtn = () => {
      if (!archiveBtn) return;
      archiveBtn.style.display = convMessages.length >= 4 ? 'inline-flex' : 'none';
    };

    const summarizeAndArchive = async () => {
      if (convMessages.length < 2 || isLoading) return;
      isLoading = true;
      if (archiveBtn) archiveBtn.disabled = true;
      showLoading(true);
      try {
        const summaryMessages = [
          ...convMessages,
          { role: 'user', content: 'Bitte erstelle eine prägnante Sitzungszusammenfassung (max. 5 Stichpunkte, 150 Wörter): Hauptthemen, wichtige Erkenntnisse, empfohlene nächste Schritte. Antworte auf Deutsch.' },
        ];
        const boardState = (window as any).__gekkoBoardData?.();
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: summaryMessages, boardState, tier: 'fast' }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        const summary = data.text?.trim() || 'Keine Zusammenfassung verfügbar.';
        const mem = saveMemory(summary);
        currentMemory = mem;
        memoryInjected = false;
        // Reset chat
        convMessages.length = 0;
        pendingToolResultIds = [];
        if (msgList) msgList.innerHTML = '';
        const trayElInner = document.getElementById('gekko-proposals') as HTMLElement | null;
        if (trayElInner) trayElInner.style.display = 'none';
        showMemoryBanner(mem);
        const confirm = document.createElement('div');
        confirm.className = 'msg-ai';
        confirm.innerHTML = `<div class="msg-ai-bubble" style="border:1px solid rgba(0,255,136,0.18);background:rgba(0,255,136,0.04);color:rgba(255,255,255,0.65);">✓ Session archiviert. Neuer Chat — Zusammenfassung ist oben sichtbar.</div>`;
        appendMsg(confirm);
        updateArchiveBtn();
      } catch (err: any) {
        addAiMsg(`Fehler beim Archivieren: ${err?.message || 'unbekannt'}`, null);
      } finally {
        isLoading = false;
        if (archiveBtn) archiveBtn.disabled = false;
        showLoading(false);
      }
    };

    archiveBtn?.addEventListener('click', summarizeAndArchive);

    // Load memory on init
    currentMemory = loadMemory();
    if (currentMemory) showMemoryBanner(currentMemory);

    // ── drag to move ─────────────────────────────────────────────────────────
    let dragging = false;
    let dsx = 0, dsy = 0, dpx = 0, dpy = 0;

    hdr.addEventListener('mousedown', (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest('button')) return;
      dragging = true;
      dsx = e.clientX;
      dsy = e.clientY;
      const r = panel.getBoundingClientRect();
      dpx = r.left;
      dpy = r.top;
      panel.style.right = 'auto';
      panel.style.bottom = 'auto';
      e.preventDefault();
    });
    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (!dragging) return;
      const nx = Math.max(0, Math.min(window.innerWidth - 80, dpx + e.clientX - dsx));
      const ny = Math.max(0, Math.min(window.innerHeight - 60, dpy + e.clientY - dsy));
      panel.style.left = nx + 'px';
      panel.style.top  = ny + 'px';
    });
    document.addEventListener('mouseup', () => { dragging = false; resizing = false; });

    // ── bottom-left resize handle ────────────────────────────────────────────
    const resizeHandle = document.getElementById('gekko-resize') as HTMLElement | null;
    let resizing = false;
    let rsStartX = 0, rsStartY = 0, rsStartW = 0, rsStartH = 0, rsRightEdge = 0;

    resizeHandle?.addEventListener('mousedown', (e: MouseEvent) => {
      resizing = true;
      rsStartX = e.clientX;
      rsStartY = e.clientY;
      const r = panel.getBoundingClientRect();
      rsStartW = r.width;
      rsStartH = r.height;
      rsRightEdge = r.right;
      panel.style.right = 'auto';
      panel.style.bottom = 'auto';
      panel.style.left = r.left + 'px';
      panel.style.top  = r.top  + 'px';
      e.preventDefault();
      e.stopPropagation();
    });
    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (!resizing) return;
      const dx = e.clientX - rsStartX;
      const dy = e.clientY - rsStartY;
      const newW = Math.max(240, Math.min(640, rsStartW - dx));
      const newH = Math.max(260, Math.min(window.innerHeight * 0.88, rsStartH + dy));
      panel.style.left   = (rsRightEdge - newW) + 'px';
      panel.style.width  = newW + 'px';
      panel.style.height = newH + 'px';
    });

    // ── scroll helpers ───────────────────────────────────────────────────────
    const scrollBottom = () => {
      requestAnimationFrame(() => { msgList.scrollTop = msgList.scrollHeight; });
    };
    const appendMsg = (el: HTMLElement) => { msgList.appendChild(el); scrollBottom(); };

    // ── message renderers ────────────────────────────────────────────────────
    const addUserMsg = (text: string) => {
      const el = document.createElement('div');
      el.className = 'msg-user';
      el.textContent = text;
      appendMsg(el);
    };

    const calcCostEur = (usage: any, tier: string): number | null => {
      if (!usage) return null;
      const rates: Record<string, { out: number; cr: number; inp: number }> = {
        fast:     { out: 1.25, cr: 0.08, inp: 0.80 },
        balanced: { out: 3,    cr: 0.30, inp: 3    },
        deep:     { out: 15,   cr: 1.88, inp: 3.75 },
      };
      const r = rates[tier] || rates.balanced;
      const inp = (usage.input_tokens || 0) - (usage.cache_read_input_tokens || 0);
      const usd = ((usage.output_tokens || 0) * r.out
                 + (usage.cache_read_input_tokens || 0) * r.cr
                 + inp * r.inp) / 1_000_000;
      return usd * 0.92;
    };

    const trayEl = document.getElementById('gekko-proposals') as HTMLElement | null;

    const addAiMsg = (text: string, usage: any) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'msg-ai';

      if (text) {
        const bubble = document.createElement('div');
        bubble.className = 'msg-ai-bubble';
        bubble.textContent = text;
        wrapper.appendChild(bubble);
      }

      const costEur = calcCostEur(usage, currentTier);
      if (usage) {
        const costEl = document.createElement('div');
        costEl.className = 'msg-cost';
        const tokOut = usage.output_tokens || 0;
        const tokIn  = usage.input_tokens  || 0;
        const costStr = costEur !== null ? ` · €${costEur < 0.001 ? costEur.toFixed(5) : costEur.toFixed(4)}` : '';
        costEl.textContent = `↑${tokIn} ↓${tokOut}${costStr}`;
        wrapper.appendChild(costEl);
      }

      appendMsg(wrapper);
    };

    const showProposalTray = (proposals: any[]) => {
      if (!trayEl || proposals.length === 0) return;
      trayEl.innerHTML = '';
      trayEl.style.display = 'block';

      const label = document.createElement('div');
      label.className = 'proposal-tray-label';
      label.textContent = `Gecko proposes ${proposals.length} change${proposals.length > 1 ? 's' : ''}`;
      trayEl.appendChild(label);

      let currentIdx = 0;
      let currentCard: HTMLElement | null = null;

      const showOne = (idx: number) => {
        currentCard?.remove();
        if (idx >= proposals.length) {
          trayEl.style.display = 'none';
          return;
        }
        const change = proposals[idx];
        const card = document.createElement('div');
        card.className = 'proposal-card';
        currentCard = card;

        const typeLabel = document.createElement('div');
        typeLabel.className = 'proposal-type';
        typeLabel.textContent = `${formatChangeType(change.type)} · ${idx + 1}/${proposals.length}`;
        card.appendChild(typeLabel);

        const desc = document.createElement('div');
        desc.className = 'proposal-desc';
        desc.textContent = describeChange(change);
        card.appendChild(desc);

        if (change.reason) {
          const reason = document.createElement('div');
          reason.className = 'proposal-reason';
          reason.textContent = change.reason;
          card.appendChild(reason);
        }

        const btns = document.createElement('div');
        btns.className = 'proposal-btns';

        const advance = () => { currentIdx++; setTimeout(() => showOne(currentIdx), 60); };

        const acceptBtn = document.createElement('button');
        acceptBtn.className = 'proposal-accept';
        acceptBtn.textContent = '✓ Accept';
        acceptBtn.addEventListener('click', () => {
          document.dispatchEvent(new CustomEvent('gekko:apply-change', { detail: change }));
          card.classList.add('accepted');
          const st = document.createElement('div');
          st.className = 'proposal-status';
          st.textContent = '✓ Applied';
          btns.replaceWith(st);
          advance();
        });

        const skipBtn = document.createElement('button');
        skipBtn.className = 'proposal-decline';
        skipBtn.textContent = '✕ Skip';
        skipBtn.addEventListener('click', () => {
          card.classList.add('declined');
          const st = document.createElement('div');
          st.className = 'proposal-status';
          st.textContent = '— Skipped';
          btns.replaceWith(st);
          advance();
        });

        const discussBtn = document.createElement('button');
        discussBtn.className = 'proposal-discuss';
        discussBtn.textContent = '↩ Discuss';
        discussBtn.addEventListener('click', () => {
          if (inputEl) { inputEl.value = `Re: "${describeChange(change)}" — `; inputEl.focus(); }
          card.classList.add('declined');
          const st = document.createElement('div');
          st.className = 'proposal-status';
          st.textContent = '↩ Discuss';
          btns.replaceWith(st);
          advance();
        });

        btns.appendChild(acceptBtn);
        btns.appendChild(skipBtn);
        btns.appendChild(discussBtn);
        card.appendChild(btns);
        trayEl.appendChild(card);
      };

      showOne(0);
    };

    let loadingEl: HTMLElement | null = null;
    const showLoading = (on: boolean) => {
      if (on) {
        loadingEl = document.createElement('div');
        loadingEl.className = 'msg-loading';
        loadingEl.textContent = 'Gecko is thinking…';
        appendMsg(loadingEl);
      } else {
        loadingEl?.remove();
        loadingEl = null;
      }
    };

    // ── send ─────────────────────────────────────────────────────────────────
    const sendMessage = async () => {
      const text = inputEl.value.trim();
      if (!text || isLoading) return;

      // Build user content: if there are pending tool_results from the last AI turn,
      // combine them with the new text in one user message (Anthropic requirement).
      let userContent: any;
      if (pendingToolResultIds.length > 0) {
        userContent = [
          ...pendingToolResultIds.map(id => ({ type: 'tool_result', tool_use_id: id, content: 'Proposals displayed to user.' })),
          { type: 'text', text },
        ];
        pendingToolResultIds = [];
      } else {
        userContent = text;
      }

      convMessages.push({ role: 'user', content: userContent });
      inputEl.value = '';
      addUserMsg(text);

      isLoading = true;
      sendBtn.disabled = true;
      showLoading(true);

      try {
        const boardState = (window as any).__gekkoBoardData?.();
        const memoryPayload = (!memoryInjected && currentMemory) ? currentMemory.summary : null;
        if (memoryPayload) memoryInjected = true;
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: convMessages, boardState, tier: currentTier, memory: memoryPayload }),
        });

        if (!res.ok) {
          const errText = await res.text().catch(() => '');
          let errMsg = `HTTP ${res.status}`;
          if (res.status === 504) errMsg = 'Request timed out (504). Try again or switch to Fast ⚡ mode.';
          else if (res.status === 500) { try { errMsg = JSON.parse(errText)?.error || errText || 'Server error'; } catch { errMsg = errText || 'Server error'; } }
          else errMsg = errText || res.statusText || errMsg;
          addAiMsg(errMsg, null);
          return;
        }

        const data = await res.json();
        const replyText: string  = data.text || '';
        const proposals: any[]   = data.proposals || [];
        const usage: any         = data.usage || null;
        const rawContent: any[]  = data.rawContent || [];

        if (rawContent.length > 0) {
          // Store the full assistant content (may include tool_use blocks)
          convMessages.push({ role: 'assistant', content: rawContent });
          // Record tool_use ids so the next user turn includes tool_results
          const toolUseIds = rawContent.filter((c: any) => c.type === 'tool_use').map((c: any) => c.id);
          if (toolUseIds.length > 0) pendingToolResultIds = toolUseIds;
        } else if (replyText) {
          convMessages.push({ role: 'assistant', content: replyText });
        }

        addAiMsg(replyText, usage);
        if (proposals.length > 0) showProposalTray(proposals);
        updateArchiveBtn();
      } catch (err: any) {
        addAiMsg(`Connection error: ${err?.message || 'unknown'}`, null);
      } finally {
        isLoading = false;
        sendBtn.disabled = false;
        showLoading(false);
      }
    };

    sendBtn.addEventListener('click', sendMessage);
    inputEl.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });

    // ── helpers ───────────────────────────────────────────────────────────────
    const formatChangeType = (type: string) => {
      const map: Record<string, string> = {
        create_node: 'Add node',
        update_node: 'Update node',
        delete_node: 'Remove node',
        create_edge: 'Add connection',
        delete_edge: 'Remove connection',
      };
      return map[type] || type;
    };

    const describeChange = (change: any): string => {
      switch (change.type) {
        case 'create_node':
          return `"${change.fields?.title || change.new_key}" (${change.fields?.cat || 'node'})`;
        case 'update_node':
          return `"${change.node_key}"${change.fields?.title ? ` → "${change.fields.title}"` : ''}${change.fields?.status ? ` · ${change.fields.status}` : ''}`;
        case 'delete_node':
          return `"${change.node_key}"`;
        case 'create_edge':
          return `${change.from_node} → ${change.to_node}`;
        case 'delete_edge':
          return `${change.from_node} → ${change.to_node}`;
        default:
          return change.type;
      }
    };
  }
</script>
