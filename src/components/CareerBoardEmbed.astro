      container.querySelectorAll('#se-c, #sa-c').forEach((selectElement) => {
        selectElement.innerHTML = '';
        Object.entries(CATS).forEach(([key, value]) => {
          const option = document.createElement('option');
          option.value = key;
          option.textContent = value.l;
          selectElement.appendChild(option);
        });
      });

      const getPM = (t1, t2) => {
        let sl = [];
        if (t2) {
          const separatorIndex = t2.indexOf(' · ');
          if (separatorIndex >= 0) sl = [t2.slice(0, separatorIndex), t2.slice(separatorIndex + 3)];
          else if (t2.length > 20) {
            const splitPoint = t2.lastIndexOf(' ', Math.floor(t2.length / 2));
            sl = splitPoint > 0 ? [t2.slice(0, splitPoint), t2.slice(splitPoint + 1)] : [t2];
          } else sl = [t2];
        }
        const tw = (t1 || '').length * 5.8 / 2;
        const sw = sl.reduce((maxWidth, line) => Math.max(maxWidth, line.length * 4.8 / 2), 0);
        const r = Math.round(Math.max(50, Math.min(90, Math.max(tw, sw) + 26)));
        return { r, sl };
      };

      const normalizeNodeUrl = (rawValue) => {
        const trimmedValue = rawValue.trim();
        if (!trimmedValue) return '';

        try {
          return new URL(trimmedValue).toString();
        } catch {
          try {
            return new URL(`https://${trimmedValue}`).toString();
          } catch {
            return '';
          }
        }
      };

      const renderClr = () => {
        const cp = container.querySelector('#pe-c');
        if (!cp) return;
        cp.innerHTML = '';
        PC.forEach((palette) => {
          const button = document.createElement('div');
          button.className = `clr${selClr === palette.id ? ' on' : ''}`;
          button.style.background = palette.c;
          button.addEventListener('click', () => {
            selClr = palette.id;
            renderClr();
          });
          cp.appendChild(button);
        });
      };
      renderClr();

      const gc = (id) => {
        if (id === HOME_ID) return { x: HOME_POS.x, y: HOME_POS.y - 24 };
        if (pmap[id]) return { x: pmap[id].x, y: pmap[id].y };
        if (nmap[id]) return { x: nmap[id].x, y: nmap[id].y };
        return null;
      };

      const defs = E('defs', {}, svg);
      const homeGlow = E('radialGradient', { id: 'homeGlow', cx: '50%', cy: '18%', r: '82%' }, defs);
      E('stop', { offset: '0%', 'stop-color': 'rgba(136,204,255,0.95)' }, homeGlow);
      E('stop', { offset: '48%', 'stop-color': 'rgba(55,138,221,0.42)' }, homeGlow);
      E('stop', { offset: '100%', 'stop-color': 'rgba(55,138,221,0)' }, homeGlow);
      const homeShelf = E('linearGradient', { id: 'homeShelf', x1: '0%', y1: '0%', x2: '0%', y2: '100%' }, defs);
      E('stop', { offset: '0%', 'stop-color': '#5CAEFF', 'stop-opacity': '0.62' }, homeShelf);
      E('stop', { offset: '58%', 'stop-color': '#2377C9', 'stop-opacity': '0.28' }, homeShelf);
      E('stop', { offset: '100%', 'stop-color': '#0A2440', 'stop-opacity': '0' }, homeShelf);
      const flt = E('filter', { id: 'glow', x: '-80%', y: '-80%', width: '260%', height: '260%' }, defs);
      E('feGaussianBlur', { in: 'SourceGraphic', stdDeviation: '2.8', result: 'b' }, flt);
      const fm = E('feMerge', {}, flt);
      E('feMergeNode', { in: 'b' }, fm);
      E('feMergeNode', { in: 'SourceGraphic' }, fm);
      const mk = E('marker', { id: 'arr', markerWidth: '6', markerHeight: '6', refX: '5.5', refY: '3', orient: 'auto' }, defs);
      E('path', { d: 'M0,0 L0,6 L6,3Z', fill: 'rgba(255,255,255,0.18)' }, mk);
      const mkc = E('marker', { id: 'arrc', markerWidth: '6', markerHeight: '6', refX: '5.5', refY: '3', orient: 'auto' }, defs);
      E('path', { d: 'M0,0 L0,6 L6,3Z', fill: 'rgba(239,159,39,0.75)' }, mkc);
      // Radial gradient backgrounds for milestone stars (center opaque → edge transparent)
      [
        { key: 'job',       c0: 'rgba(43,148,108,0.58)',  c1: 'rgba(43,148,108,0)' },
        { key: 'education', c0: 'rgba(95,123,214,0.58)',  c1: 'rgba(95,123,214,0)' },
        { key: 'other',     c0: 'rgba(176,92,68,0.58)',   c1: 'rgba(176,92,68,0)' },
      ].forEach(({ key, c0, c1 }) => {
        const g = E('radialGradient', { id: `sgrd-${key}`, cx: '0', cy: '0', r: '13', gradientUnits: 'userSpaceOnUse' }, defs);
        E('stop', { offset: '0%', 'stop-color': c0 }, g);
        E('stop', { offset: '100%', 'stop-color': c1 }, g);
      });

      const bg = E('g', {}, svg);
      for (let i = 0; i < 90; i += 1) {
        const star = E('circle', {
          cx: (Math.random() * 900).toFixed(1),
          cy: (Math.random() * 580).toFixed(1),
          r: (Math.random() * 1 + 0.3).toFixed(2),
          fill: 'white',
          opacity: (Math.random() * 0.3 + 0.07).toFixed(2),
        }, bg);
        const twinkle = Math.random() < 0.07;
        bgStars.push({
          el: star,
          baseOpacity: Math.random() * 0.22 + 0.08,
          baseRadius: Number(star.getAttribute('r') || '0.5'),
          twinkle,
          speed: twinkle ? (Math.random() * 0.035 + 0.022) : 0,
          phase: Math.random() * Math.PI * 2,
        });
      }

      const pg = E('g', {}, svg);
  // E('ellipse', { cx: '450', cy: '594', rx: '640', ry: '118', fill: 'url(#homeGlow)', opacity: '0.85' }, pg);
  E('path', { d: 'M -80 582 Q 450 490 980 582 L 980 650 L -80 650 Z', fill: 'url(#homeShelf)', opacity: '0.94' }, pg);
  // E('path', { d: 'M -58 520 Q 450 468 958 520', fill: 'none', stroke: 'rgba(165,216,255,0.34)', 'stroke-width': '1.7' }, pg);
  E('path', { d: 'M -42 430 Q 450 404 942 430', fill: 'none', stroke: 'rgba(132,183,235,0.14)', 'stroke-width': '1.35' }, pg);
      E('path', { d: 'M -30 302 Q 450 282 930 302', fill: 'none', stroke: 'rgba(132,183,235,0.12)', 'stroke-width': '1.15' }, pg);
      const tlNear = E('text', { x: '56', y: '456', 'font-size': '10', fill: 'rgba(255,255,255,0.28)', cursor: 'pointer' }, pg);
      const tlMid = E('text', { x: '56', y: '350', 'font-size': '10', fill: 'rgba(255,255,255,0.28)', cursor: 'pointer' }, pg);
      const tlFar = E('text', { x: '56', y: '242', 'font-size': '10', fill: 'rgba(255,255,255,0.28)', cursor: 'pointer' }, pg);
      const bt1 = E('text', { x: '450', y: '552', 'text-anchor': 'middle', 'font-size': '9.5', fill: 'rgba(255,255,255,0.48)' }, pg);
      const bt2 = E('text', { x: '450', y: '567', 'text-anchor': 'middle', 'font-size': '9', fill: 'rgba(255,255,255,0.3)' }, pg);
      const phr = E('rect', { x: '0', y: '500', width: '900', height: '80', fill: 'transparent' }, pg);

  homeGroup = E('g', { id: 'hm-cur', class: 'hm', 'data-home-id': HOME_ID }, svg);
  //  E('ellipse', { cx: String(HOME_POS.x), cy: String(HOME_POS.y - 14), rx: '108', ry: '34', fill: 'rgba(92,174,255,0.08)', opacity: '0.95' }, homeGroup);
  E('rect', { x: '330', y: '500', width: '240', height: '92', fill: 'transparent' }, homeGroup);

      const updateBaseLabels = () => {
        tlNear.textContent = boardMeta.timelineNear;
        tlMid.textContent = boardMeta.timelineMid;
        tlFar.textContent = boardMeta.timelineFar;
        bt1.textContent = boardMeta.homeLine1;
        bt2.textContent = boardMeta.homeLine2;
      };

      updateBaseLabels();

      egG = E('g', { id: 'eg' }, svg);
      plG = E('g', { id: 'pl' }, svg);
      sgG = E('g', { id: 'sg' }, svg);

      const drawEdges = () => {
        while (egG.lastChild) egG.removeChild(egG.lastChild);
        const inC = mode === 'connecting';
        edges.forEach((edge, idx) => {
          const a = gc(edge.f);
          const b = gc(edge.t);
          if (!a || !b) return;
          const isConnected = inC && (edge.f === conn || edge.t === conn);
          // Arrow always points upward: ensure marker-end is at the higher node (lower y)
          const [p0, p1] = a.y <= b.y ? [b, a] : [a, b];
          E('path', {
            d: `M${p0.x},${p0.y} C${p0.x},${p0.y + (p1.y - p0.y) * 0.42} ${p1.x},${p1.y - (p1.y - p0.y) * 0.42} ${p1.x},${p1.y}`,
            fill: 'none',
            stroke: isConnected ? 'rgba(239,159,39,0.55)' : 'rgba(255,255,255,0.09)',
            'stroke-width': isConnected ? '2' : '1.2',
            'marker-end': isConnected ? 'url(#arrc)' : 'url(#arr)',
          }, egG);
          if (isConnected && mode === 'connecting') {
            const mx = (a.x + b.x) / 2;
            const my = (a.y + b.y) / 2;
            const btn = E('g', { cursor: 'pointer', class: 'del-edge' }, egG);
            E('circle', { cx: String(mx), cy: String(my), r: '9', fill: 'rgba(215,55,45,0.9)' }, btn);
            const xt = E('text', { x: String(mx), y: String(my + 4), 'text-anchor': 'middle', 'font-size': '11', 'font-weight': '500', fill: 'white', 'pointer-events': 'none' }, btn);
            xt.textContent = '✕';
            btn.addEventListener('click', (ev) => {
              ev.stopPropagation();
              const removed = edges.splice(idx, 1)[0];
              if (removed) dbDeleteEdge(removed.f, removed.t);
              drawEdges();
            });
          }
        });
      };

      const DBG = 'rgba(16,22,40,0.9)';
      const mkDock = (group, cx, cy, id, variant = 'node') => {
        const dockGroup = E('g', {
          id: `dk-${id}`,
          opacity: '0',
          cursor: 'pointer',
          class: `dock-target dock-target--${variant}`,
          'data-dock-id': id,
        }, group);
        E('circle', { cx: String(cx), cy: String(cy), r: '11', fill: 'rgba(14,28,54,0.96)', stroke: 'rgba(125,204,255,0.95)', 'stroke-width': '1.7' }, dockGroup);
        E('circle', { cx: String(cx), cy: String(cy), r: '5.1', fill: '#7FD4FF', opacity: '0.98' }, dockGroup);
        E('path', { d: `M${cx - 4},${cy} L${cx + 4},${cy} M${cx},${cy - 4} L${cx},${cy + 4}`, stroke: 'white', 'stroke-width': '1.1', 'stroke-linecap': 'round', opacity: '0.88' }, dockGroup);
        dockGroup.addEventListener('mousedown', (event) => { event.stopPropagation(); event.preventDefault(); });
        dockGroup.addEventListener('click', (event) => {
          event.stopPropagation();
          if (mode !== 'connecting' || id === conn) return;
          completeConnection(id);
        });
        docks[id] = dockGroup;
        return dockGroup;
      };
      const mkDots = (group, cx, cy, id, isPlanet) => {
        const dotGroup = E('g', { id: `${isPlanet ? 'pd' : 'd'}-${id}`, opacity: '0', cursor: 'pointer' }, group);
        E('circle', { cx: String(cx), cy: String(cy), r: '9', fill: DBG }, dotGroup);
        [-3.5, 0, 3.5].forEach((dy) => {
          E('circle', { cx: String(cx), cy: String(cy + dy), r: '1.3', fill: 'rgba(255,255,255,0.85)' }, dotGroup);
        });
        return dotGroup;
      };
      const mkPlus = (group, cx, cy, id, isPlanet) => {
        const controlGroup = E('g', { id: `${isPlanet ? 'pa' : 'a'}-${id}`, opacity: '0', cursor: 'pointer', class: 'conn-ctrl', 'pointer-events': 'none' }, group);
        E('circle', { cx: String(cx), cy: String(cy), r: '8.5', fill: '#1D9E75', opacity: '0.9' }, controlGroup);
        const pt = E('text', { id: `${isPlanet ? 'pp' : 'p'}-${id}`, x: String(cx), y: String(cy + 4.5), 'text-anchor': 'middle', 'font-size': '13', 'font-weight': '500', fill: 'white' }, controlGroup);
        pt.textContent = '+';
        return controlGroup;
      };
      const aop = (opacity, exceptId) => {
        nodes.forEach((node) => {
          if (nels[node.id] && node.id !== exceptId) nels[node.id].setAttribute('opacity', String(opacity));
        });
        planets.forEach((planet) => {
          if (pels[planet.id] && planet.id !== exceptId) pels[planet.id].setAttribute('opacity', String(opacity));
        });
        if (homeGroup && HOME_ID !== exceptId) homeGroup.setAttribute('opacity', String(opacity));
      };
      const showDockTargets = (isVisible, exceptId = null) => {
        Object.entries(docks).forEach(([id, element]) => {
          if (!(element instanceof SVGGElement)) return;
          const isActive = isVisible && id !== exceptId;
          element.setAttribute('opacity', isActive ? '1' : '0');
          element.setAttribute('data-dock-active', isActive ? 'true' : 'false');
        });
      };
      const completeConnection = (targetId) => {
        if (!conn || targetId === conn) return;
        if (!edges.some((edge) => edge.f === conn && edge.t === targetId)) {
          edges.push({ f: conn, t: targetId });
          dbInsertEdge(conn, targetId);
        }
        drawEdges();
        uHint();
      };

      const makePlanetEl = (planet) => {
        const metrics = getPM(planet.t1, planet.t2);
        planet.r = metrics.r;
        const group = E('g', { id: `pl-${planet.id}`, transform: `translate(${planet.x},${planet.y})`, 'data-pid': planet.id, class: 'pn' }, plG);
        E('circle', { cx: '0', cy: '0', r: String(planet.r + 10), fill: PLANET_STYLE.glow, opacity: '1' }, group);
        E('circle', { cx: '0', cy: '0', r: String(planet.r), fill: PLANET_STYLE.shell }, group);
        E('circle', { cx: String(-planet.r * 0.08), cy: String(-planet.r * 0.1), r: String(planet.r * 0.94), fill: PLANET_STYLE.shellInner, opacity: '1' }, group);
        E('circle', { cx: String(-planet.r * 0.34), cy: String(-planet.r * 0.34), r: String(planet.r * 0.34), fill: PLANET_STYLE.haze, opacity: '1' }, group);
        E('circle', { cx: '0', cy: '0', r: String(planet.r), fill: 'none', stroke: PLANET_STYLE.atmosphere, 'stroke-width': '1.8', opacity: '0.88' }, group);
        const lines = metrics.sl.length;
        const titleY = lines === 0 ? 4 : lines === 1 ? -6 : -10;
        const title = E('text', { x: '0', y: String(titleY), 'text-anchor': 'middle', 'font-size': '10.5', 'font-weight': '500', fill: 'rgba(255,255,255,0.92)' }, group);
        title.textContent = planet.t1;
        if (lines >= 1) {
          const subtitle1 = E('text', { x: '0', y: String(lines === 1 ? 8 : 3), 'text-anchor': 'middle', 'font-size': '9', fill: 'rgba(255,255,255,0.48)' }, group);
          subtitle1.textContent = metrics.sl[0];
        }
        if (lines >= 2) {
          const subtitle2 = E('text', { x: '0', y: '15', 'text-anchor': 'middle', 'font-size': '9', fill: 'rgba(255,255,255,0.48)' }, group);
          subtitle2.textContent = metrics.sl[1];
        }
        E('circle', { cx: '0', cy: '0', r: String(planet.r + 6), fill: 'none', stroke: PLANET_STYLE.atmosphere, 'stroke-width': '2.5', opacity: '0', id: `pr-${planet.id}` }, group);
        const dc = Math.round(planet.r * 0.7);
        const dotGroup = mkDots(group, dc, -dc, planet.id, true);
        dotGroup.addEventListener('mousedown', (event) => { event.stopPropagation(); event.preventDefault(); });
        dotGroup.addEventListener('click', (event) => { event.stopPropagation(); showPCtx(planet.id, event.clientX, event.clientY); });
        mkPlus(group, 0, planet.r + 14, planet.id, true);
        mkDock(group, 0, planet.r - 16, planet.id, 'planet');
        group.addEventListener('mouseenter', () => {
          if (!hDrag && !mode && planet.detail) {
            sTip(PLANET_STYLE.atmosphere, 'Target planet', planet.t1, planet.detail, planet.x, planet.y - Math.round(planet.r / 2), null, planet.id);
            document.getElementById(`pd-${planet.id}`)?.setAttribute('opacity', '1');
          }
        });
        group.addEventListener('mouseleave', () => {
          sHide();
          document.getElementById(`pd-${planet.id}`)?.setAttribute('opacity', '0');
        });
        pmap[planet.id] = planet;
        pels[planet.id] = group;
      };

      const sp = (r) => {
        const inner = r * 0.33;
        return `M0,${-r} L${inner},${-inner} L${r},0 L${inner},${inner} L0,${r} L${-inner},${inner} L${-r},0 L${-inner},${-inner}Z`;
      };
      const makeStarEl = (node) => {
        const catKey = normalizeCategory(node.cat);
        const cat = CATS[catKey] || CATS.job;
        const status = STAT[normalizeStatus(node.status)] || STAT.planned;
        const group = E('g', { id: `sn-${node.id}`, transform: `translate(${node.x},${node.y})`, 'data-id': node.id, class: 'sn' }, sgG);
        const sprite = E('g', { class: 'sn-sprite' }, group);
        // Gradient background (no ring border), ~30% smaller than before
        const halo = E('circle', { cx: '0', cy: '0', r: '13', fill: `url(#sgrd-${catKey})`, opacity: '0.85' }, sprite);
        const sparkle = E('circle', { cx: '0', cy: '0', r: '9', fill: status.c, filter: 'url(#glow)', opacity: '0.12' }, sprite);
        const starShape = E('path', { d: sp(7), fill: status.c, filter: 'url(#glow)', opacity: status.o }, sprite);
        E('circle', { cx: '0', cy: '0', r: '13', fill: 'none', stroke: cat.c, 'stroke-width': '2.5', opacity: '0', id: `r-${node.id}` }, sprite);
          const title = E('text', { x: '14', y: '-4', 'font-size': '10', 'font-weight': '500', fill: 'rgba(255,255,255,0.9)' }, group);
        title.textContent = node.title;
          const subtitle = E('text', { x: '14', y: '9', 'font-size': '8', fill: 'rgba(255,255,255,0.4)' }, group);
        subtitle.textContent = node.sub;
        const dotGroup = mkDots(group, -13, -13, node.id, false);
        dotGroup.addEventListener('mousedown', (event) => { event.stopPropagation(); event.preventDefault(); });
        dotGroup.addEventListener('click', (event) => { event.stopPropagation(); showSCtx(node.id, event.clientX, event.clientY); });
        mkPlus(group, 0, 17, node.id, false);
        mkDock(group, 0, -17, node.id, 'star');
        group.addEventListener('mouseenter', () => {
          if (!hDrag && !mode) {
            sTip(cat.c, cat.l, node.title, node.detail, node.x, node.y - 13, node.id, null);
            document.getElementById(`d-${node.id}`)?.setAttribute('opacity', '1');
          }
        });
        group.addEventListener('mouseleave', () => {
          sHide();
          document.getElementById(`d-${node.id}`)?.setAttribute('opacity', '0');
        });
        starSprites.push({
          sprite,
          halo,
          sparkle,
          starShape,
          baseOpacity: Number(status.o),
          scale: Math.random() * 0.003 + 0.0015,
          speed: Math.random() * 0.001 + 0.00045,
          phase: Math.random() * Math.PI * 2,
        });
        nmap[node.id] = node;
        nels[node.id] = group;
      };

      planets.forEach(makePlanetEl);
      nodes.forEach(makeStarEl);
      mkPlus(homeGroup, HOME_POS.x, HOME_POS.y + 18, HOME_ID, false);
      mkDock(homeGroup, HOME_POS.x, HOME_POS.y - 42, HOME_ID, 'home');
      drawEdges();

      // ── Ambient background star particles (public board only) ──────────
      if (showResetBtn) {
        const bgG = document.createElementNS(NS, 'g');
        bgG.setAttribute('id', 'gg-bg');
        svg.insertBefore(bgG, svg.firstChild);

        const rng = () => Math.random();
        const TOTAL = 260;

        for (let i = 0; i < TOTAL; i++) {
          const isGlimmer = rng() < 0.12;
          const r   = isGlimmer ? (rng() * 0.55 + 0.85) : (rng() * 0.55 + 0.18);
          const base = isGlimmer ? (rng() * 0.10 + 0.07) : (rng() * 0.06 + 0.02);
          const c = document.createElementNS(NS, 'circle');
          c.setAttribute('cx', (rng() * VW).toFixed(1));
          c.setAttribute('cy', (rng() * VH).toFixed(1));
          c.setAttribute('r',  r.toFixed(2));
          c.setAttribute('fill', '#B8D4FF');
          c.setAttribute('opacity', '0');
          bgG.appendChild(c);
          ambientStars.push({ el: c, base, speed: rng() * 0.005 + 0.001, phase: rng() * Math.PI * 2 });
        }
      }
      // ────────────────────────────────────────────────────────────────────

      let animFrame = 0;
      const tickBoardStars = () => {
        animFrame += 1;

        for (const star of bgStars) {
          if (!star.twinkle) {
            star.el.setAttribute('opacity', star.baseOpacity.toFixed(4));
            star.el.setAttribute('r', star.baseRadius.toFixed(3));
            continue;
          }

          const flash = Math.max(0, Math.sin(animFrame * star.speed + star.phase));
          const opacity = star.baseOpacity + flash * 0.12;
          const radius = star.baseRadius * (1 + flash * 0.05);
          star.el.setAttribute('opacity', opacity.toFixed(4));
          star.el.setAttribute('r', radius.toFixed(3));
        }

        for (const star of ambientStars) {
          const opacity = star.base * (0.35 + 0.65 * Math.sin(animFrame * star.speed + star.phase));
          star.el.setAttribute('opacity', opacity.toFixed(4));
        }

        for (const star of starSprites) {
          const wave = Math.sin(animFrame * star.speed + star.phase);
          const shimmer = 0.5 + 0.5 * Math.sin(animFrame * (star.speed * 1.3) + star.phase * 1.2);
          const scale = 1 + wave * star.scale;

          star.sprite.setAttribute('transform', `scale(${scale.toFixed(4)})`);
          star.starShape.setAttribute('opacity', (star.baseOpacity * (0.94 + shimmer * 0.08)).toFixed(4));
          star.sparkle.setAttribute('opacity', (0.1 + shimmer * 0.08).toFixed(4));
          star.halo.setAttribute('opacity', (0.26 + shimmer * 0.1).toFixed(4));
        }

        requestAnimationFrame(tickBoardStars);
      };
      tickBoardStars();

      const enterConn = (id) => {
        if (mode) exitConn(false);
        conn = id;
        mode = 'connecting';
        const isPlanet = Boolean(pmap[id]);
        document.getElementById(`${isPlanet ? 'pr' : 'r'}-${id}`)?.setAttribute('opacity', '0.9');
        document.getElementById(`${isPlanet ? 'pr' : 'r'}-${id}`)?.setAttribute('stroke', '#EF9F27');
        aop(1, id);
        showDockTargets(true, id);
        hTip(true);
        drawEdges();
        uHint();
      };
      const exitConn = (redraw = true) => {
        if (conn) {
          const isPlanet = Boolean(pmap[conn]);
          const ring = document.getElementById(`${isPlanet ? 'pr' : 'r'}-${conn}`);
          if (ring) {
            ring.setAttribute('stroke', '#378ADD');
            ring.setAttribute('opacity', '0');
          }
          aop(1);
          showDockTargets(false);
        }
        conn = null;
        mode = null;
        hTip(true);
        if (redraw) drawEdges();
        uHint();
      };
      const uHint = () => {
        const hint = container.querySelector('#hint');
        if (!hint) return;
        if (mode === 'connecting') hint.textContent = 'Click any blue dock to connect · click empty to exit';
        else hint.textContent = 'Hover for info · drag to move · right-click for options';
      };

      const escHtml = (value) => {
        const div = document.createElement('div');
        div.textContent = value;
        return div.innerHTML;
      };
      const sTip = (color, cls, title, detail, sx, sy, nid, pid) => {
        if (mode) return;
        if (ht) clearTimeout(ht);
        const sr = svg.getBoundingClientRect();
        const wr = container.querySelector('.cvwrap').getBoundingClientRect();
        const viewportPoint = boardToViewport(sx, sy);
        let px = viewportPoint.x * sr.width + (sr.left - wr.left) + 18;
        let py = viewportPoint.y * sr.height + (sr.top - wr.top) - 8;
        if (px + 308 > wr.width - 10) px -= 320;
        if (py < 5) py = 5;
        tip.style.cssText = `display:block;position:absolute;z-index:30;width:220px;border-radius:10px;padding:10px 12px;pointer-events:all;border:1px solid ${color}4D;background:rgba(6,10,22,0.97);left:${px}px;top:${py}px;`;
        let pen = '';
        if (nid === 'home') pen = '<span class="tip-e" data-action="etip" data-eid="home" data-etype="h">✎</span>';
        else if (nid && nid.startsWith('timeline-')) pen = `<span class="tip-e" data-action="etip" data-eid="${nid}" data-etype="t">✎</span>`;
        else if (nid) pen = `<span class="tip-e" data-action="etip" data-eid="${nid}" data-etype="s">✎</span>`;
        else if (pid) pen = `<span class="tip-e" data-action="etip" data-eid="${pid}" data-etype="p">✎</span>`;
        const safeDetail = detail ? detail.replace(/\n/g, '<br>') : '';
        const rawUrl = nid && nmap[nid]?.url ? nmap[nid].url : '';
        const safeUrl = rawUrl ? escHtml(rawUrl) : '';
        const tipWidth = rawUrl ? 300 : 220;
        tip.style.width = `${tipWidth}px`;
        let domain = '';
        try { domain = new URL(rawUrl).hostname.replace(/^www\./, ''); } catch {}
        const faviconSrc = rawUrl ? `https://www.google.com/s2/favicons?domain_url=${encodeURIComponent(rawUrl)}&sz=64` : '';
        tip.innerHTML = `<div style="position:relative;">${pen}<div style="font-size:8.5px;font-weight:500;text-transform:uppercase;letter-spacing:.07em;color:${color};margin-bottom:4px;">${cls}</div><div style="font-size:12px;font-weight:500;color:rgba(255,255,255,0.95);margin-bottom:4px;">${escHtml(title)}</div>${safeDetail ? `<div style="font-size:10.5px;color:rgba(255,255,255,0.62);line-height:1.55;">${safeDetail}</div>` : ''}${rawUrl ? `<div class="tip-url-wrap" style="margin-top:10px;position:relative;width:100%;padding-top:56.25%;border-radius:7px;overflow:hidden;background:rgba(255,255,255,0.06);cursor:pointer;"><div class="tip-placeholder" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;"><img src="${faviconSrc}" style="width:22px;height:22px;border-radius:4px;display:block;" alt=""><span style="font-size:8.5px;color:rgba(255,255,255,0.4);letter-spacing:.02em;">${escHtml(domain)}</span><span style="font-size:7.5px;color:rgba(255,255,255,0.2);letter-spacing:.06em;">loading preview …</span></div><img class="tip-preview" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top left;display:block;opacity:0;transition:opacity .3s;" alt=""><span class="tip-open" style="display:none;position:absolute;bottom:0;left:0;right:0;padding:5px 8px;background:linear-gradient(0deg,rgba(0,0,0,0.6),transparent);font-size:8.5px;color:rgba(255,255,255,0.55);letter-spacing:.04em;border-radius:0 0 7px 7px;pointer-events:none;">click to open</span></div>` : ''}</div>`;
        if (rawUrl) {
          const previewImg = tip.querySelector('.tip-preview');
          const urlWrap = tip.querySelector('.tip-url-wrap');
          const placeholder = tip.querySelector('.tip-placeholder');
          const openLabel = tip.querySelector('.tip-open');
          if (previewImg && urlWrap) {
            previewImg.src = `https://image.thum.io/get/width/600/viewportWidth/1280/crop/338/${rawUrl}`;
            previewImg.onload = () => {
              previewImg.style.opacity = '1';
              if (placeholder) placeholder.remove();
              if (openLabel) openLabel.style.display = 'block';
            };
            previewImg.onerror = () => {
              previewImg.remove();
              if (placeholder) {
                placeholder.style.cssText = 'position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;pointer-events:auto;';
                const link = document.createElement('a');
                link.href = safeUrl;
                link.target = '_blank';
                link.rel = 'noopener noreferrer';
                link.textContent = 'WEBLINK';
                link.style.cssText = 'color:#5BA7E8;font-weight:700;letter-spacing:.12em;font-size:10px;text-decoration:underline;';
                link.onclick = (e) => e.stopPropagation();
                placeholder.replaceChildren(link);
              }
            };
            urlWrap.onclick = (e) => { e.stopPropagation(); window.open(rawUrl, '_blank', 'noopener,noreferrer'); };
          }
        }
      };

      function sHide() {
        ht = setTimeout(() => {
          tip.style.display = 'none';
        }, 130);
      }

      const hTip = (instant = false) => {
        if (instant) tip.style.display = 'none';
        else sHide();
      };
      tip.addEventListener('mouseenter', () => {
        if (ht) clearTimeout(ht);
      });
      tip.addEventListener('mouseleave', sHide);

      const posCtx = (cx, cy) => {
        const wr = container.querySelector('.cvwrap').getBoundingClientRect();
        let mx = cx - wr.left;
        let my = cy - wr.top;
        if (mx + 172 > wr.width) mx -= 172;
        if (my + 145 > wr.height) my -= 145;
        if (mx < 4) mx = 4;
        if (my < 4) my = 4;
        ctx.style.left = `${mx}px`;
        ctx.style.top = `${my}px`;
        ctx.style.display = 'block';
      };
      const hCtx = () => { ctx.style.display = 'none'; };
      const showHCtx = (cx, cy) => {
        cxId = 'home';
        cxT = 'h';
        ctx.innerHTML = '<div class="ci" data-action="oHE">✎&nbsp;&nbsp;Edit starting point</div><div class="ci" data-action="oCC">⟶&nbsp;&nbsp;Edit connections</div>';
        posCtx(cx, cy);
        hTip(true);
      };
      const showSCtx = (id, cx, cy) => {
        cxId = id;
        cxT = 's';
        ctx.innerHTML = '<div class="ci" data-action="oCT">✎&nbsp;&nbsp;Edit text</div><div class="ci" data-action="oCC">⟶&nbsp;&nbsp;Edit connections</div><div class="cs"></div><div class="ci" data-action="oDup">⎘&nbsp;&nbsp;Duplicate</div><div class="ci" style="color:#F0997B;" data-action="oDel">✕&nbsp;&nbsp;Delete</div>';
        posCtx(cx, cy);
        hTip(true);
      };
      const showPCtx = (id, cx, cy) => {
        cxId = id;
        cxT = 'p';
        ctx.innerHTML = '<div class="ci" data-action="oCT">✎&nbsp;&nbsp;Edit planet</div><div class="ci" data-action="oCC">⟶&nbsp;&nbsp;Edit connections</div><div class="cs"></div><div class="ci" style="color:#F0997B;" data-action="oDel">✕&nbsp;&nbsp;Delete</div>';
        posCtx(cx, cy);
        hTip(true);
      };
      const showCCtx = (pos, cx, cy) => {
        apos = pos;
        ctx.innerHTML = '<div class="ci" data-action="doAS">✦&nbsp;&nbsp;Add star</div><div class="ci" data-action="doAT">◎&nbsp;&nbsp;Add target</div>';
        posCtx(cx, cy);
      };

      phr.addEventListener('mouseenter', () => {
        if (!mode) sTip('#378ADD', 'Starting point', boardMeta.homeTitle, boardMeta.homeDetail, 450, 495, 'home', null);
      });
      phr.addEventListener('mouseleave', sHide);
      homeGroup.addEventListener('mouseenter', () => {
        if (!hDrag && !mode) sTip('#378ADD', 'Starting point', boardMeta.homeTitle, boardMeta.homeDetail, 450, 495, 'home', null);
      });
      homeGroup.addEventListener('mouseleave', sHide);

      tlNear.addEventListener('mouseenter', () => { if (!mode) sTip('#85B7EB', 'Time horizon', boardMeta.timelineNear, 'Edit this horizon label.', 112, 440, 'timeline-near', null); });
      tlNear.addEventListener('mouseleave', sHide);
      tlNear.addEventListener('click', (event) => { event.stopPropagation(); openTep('near'); });
      tlMid.addEventListener('mouseenter', () => { if (!mode) sTip('#85B7EB', 'Time horizon', boardMeta.timelineMid, 'Edit this horizon label.', 112, 334, 'timeline-mid', null); });
      tlMid.addEventListener('mouseleave', sHide);
      tlMid.addEventListener('click', (event) => { event.stopPropagation(); openTep('mid'); });
      tlFar.addEventListener('mouseenter', () => { if (!mode) sTip('#85B7EB', 'Time horizon', boardMeta.timelineFar, 'Edit this horizon label.', 112, 226, 'timeline-far', null); });
      tlFar.addEventListener('mouseleave', sHide);
      tlFar.addEventListener('click', (event) => { event.stopPropagation(); openTep('far'); });

      const openPep = (id, nextMode) => {
        pepMode = nextMode;
        pepId = id;
        const planet = id ? pmap[id] : null;
        selClr = planet?.cid || 'teal';
        container.querySelector('#pe-t').value = planet?.t1 || '';
        container.querySelector('#pe-s').value = planet?.t2 || '';
        container.querySelector('#pe-d').value = planet?.detail || '';
        container.querySelector('#pep-h').textContent = nextMode === 'edit' ? 'Edit planet' : 'New target planet';
        renderClr();
        ['pep', 'sep', 'sap'].forEach((panelId) => {
          const panel = container.querySelector(`#${panelId}`);
          if (panel) panel.style.display = panelId === 'pep' ? 'block' : 'none';
        });
        container.querySelector('#pe-t').focus();
      };
      const openHep = () => {
        container.querySelector('#he-t').value = boardMeta.homeTitle || '';
        container.querySelector('#he-l1').value = boardMeta.homeLine1 || '';
        container.querySelector('#he-l2').value = boardMeta.homeLine2 || '';
        container.querySelector('#he-d').value = boardMeta.homeDetail || '';
        ['pep', 'sep', 'sap', 'tep', 'hep'].forEach((panelId) => {
          const panel = container.querySelector(`#${panelId}`);
          if (panel) panel.style.display = panelId === 'hep' ? 'block' : 'none';
        });
        container.querySelector('#he-t').focus();
      };
      const saveHep = () => {
        boardMeta.homeTitle = container.querySelector('#he-t').value.trim() || boardMeta.homeTitle;
        boardMeta.homeLine1 = container.querySelector('#he-l1').value.trim() || boardMeta.homeLine1;
        boardMeta.homeLine2 = container.querySelector('#he-l2').value.trim() || boardMeta.homeLine2;
        boardMeta.homeDetail = container.querySelector('#he-d').value.trim() || boardMeta.homeDetail;
        updateBaseLabels();
        persistLocalState();
        container.querySelector('#hep').style.display = 'none';
      };
      const closeHep = () => { container.querySelector('#hep').style.display = 'none'; };
      const openTep = (slot = 'near') => {
        container.querySelector('#te-near').value = boardMeta.timelineNear || '';
        container.querySelector('#te-mid').value = boardMeta.timelineMid || '';
        container.querySelector('#te-far').value = boardMeta.timelineFar || '';
        ['pep', 'sep', 'sap', 'hep', 'tep'].forEach((panelId) => {
          const panel = container.querySelector(`#${panelId}`);
          if (panel) panel.style.display = panelId === 'tep' ? 'block' : 'none';
        });
        container.querySelector(`#te-${slot}`).focus();
      };
      const saveTep = () => {
        boardMeta.timelineNear = container.querySelector('#te-near').value.trim() || boardMeta.timelineNear;
        boardMeta.timelineMid = container.querySelector('#te-mid').value.trim() || boardMeta.timelineMid;
        boardMeta.timelineFar = container.querySelector('#te-far').value.trim() || boardMeta.timelineFar;
        updateBaseLabels();
        persistLocalState();
        container.querySelector('#tep').style.display = 'none';
      };
      const closeTep = () => { container.querySelector('#tep').style.display = 'none'; };
      const savePep = () => {
        const t1 = container.querySelector('#pe-t').value.trim();
        if (!t1) return;
        const t2 = container.querySelector('#pe-s').value.trim();
        const det = container.querySelector('#pe-d').value.trim();
        const palette = pcm[selClr] || pcm.teal;
        if (pepMode === 'edit') {
          const planet = pmap[pepId];
          if (!planet) return;
          planet.t1 = t1;
          planet.t2 = t2;
          planet.detail = det;
          planet.cid = selClr;
          document.getElementById(`pl-${planet.id}`)?.remove();
          delete pels[planet.id];
          makePlanetEl(planet);
          drawEdges();
          dbUpsertNode(planet.id, { cat: 'destination', title: t1, subtitle: t2, detail: det, x: planet.x, y: planet.y, color: palette.c, dark_color: palette.k, radius: planet.r });
        } else {
          const pos = apos || { x: 450, y: 110 };
          const nk = `p${Date.now()}`;
          const planet = { id: nk, t1, t2, detail: det, x: Math.min(pos.x, VW - 100), y: Math.min(pos.y, 170), cid: selClr, r: 68 };
          planets.push(planet);
          makePlanetEl(planet);
          drawEdges();
          apos = null;
          dbInsertNode(nk, { cat: 'destination', title: t1, subtitle: t2, detail: det, status: 'planned', x: planet.x, y: planet.y, color: palette.c, dark_color: palette.k, radius: planet.r });
        }
        container.querySelector('#pep').style.display = 'none';
      };
      const closePep = () => { container.querySelector('#pep').style.display = 'none'; };

      const openSep = (id) => {
        const node = nmap[id];
        if (!node) return;
        editId = id;
        container.querySelector('#se-t').value = node.title || '';
        container.querySelector('#se-s').value = node.sub || '';
        container.querySelector('#se-u').value = node.url || '';
        container.querySelector('#se-d').value = node.detail || '';
        container.querySelector('#se-c').value = node.cat || 'cert';
        container.querySelector('#se-st').value = node.status || 'planned';
        ['pep', 'sep', 'sap'].forEach((panelId) => {
          const panel = container.querySelector(`#${panelId}`);
          if (panel) panel.style.display = panelId === 'sep' ? 'block' : 'none';
        });
      };
      const saveSep = () => {
        const node = nmap[editId];
        if (!node) return;
        node.title = container.querySelector('#se-t').value.trim() || node.title;
        node.sub = container.querySelector('#se-s').value.trim();
        node.url = normalizeNodeUrl(container.querySelector('#se-u').value);
        node.detail = container.querySelector('#se-d').value.trim();
        node.cat = container.querySelector('#se-c').value;
        node.status = container.querySelector('#se-st').value;
        document.getElementById(`sn-${node.id}`)?.remove();
        delete nels[node.id];
        makeStarEl(node);
        drawEdges();
        container.querySelector('#sep').style.display = 'none';
        dbUpsertNode(node.id, { cat: node.cat, title: node.title, subtitle: node.sub, url: node.url, detail: node.detail, status: node.status, x: node.x, y: node.y });
      };
      const closeSep = () => { container.querySelector('#sep').style.display = 'none'; };
      const closeSap = () => {
        container.querySelector('#sap').style.display = 'none';
        apos = null;
      };
      const addStar = () => {
        const title = container.querySelector('#sa-t').value.trim();
        if (!title) return;
        const cat = container.querySelector('#sa-c').value;
        const status = container.querySelector('#sa-st').value;
        const sub = container.querySelector('#sa-s').value.trim() || (CATS[cat]?.l || '');
        const url = normalizeNodeUrl(container.querySelector('#sa-u').value);
        const detail = container.querySelector('#sa-d').value.trim();
        const pos = apos || { x: 400, y: 300 };
        apos = null;
        const nk = `u${Date.now()}`;
        const node = { id: nk, cat, status, title, sub, url, detail, x: pos.x, y: pos.y };
        nodes.push(node);
        makeStarEl(node);
        drawEdges();
        ['sa-t', 'sa-s', 'sa-u', 'sa-d'].forEach((inputId) => {
          const input = container.querySelector(`#${inputId}`);
          if (input) input.value = '';
        });
        container.querySelector('#sap').style.display = 'none';
        dbInsertNode(nk, { cat, title, subtitle: sub, url, detail, status, x: node.x, y: node.y });
      };
      const dupN = (id) => {
        const source = nmap[id];
        if (!source) return;
        const nk = `u${Date.now()}`;
        const node = { ...source, id: nk, x: source.x + 22, y: source.y + 22 };
        nodes.push(node);
        makeStarEl(node);
        drawEdges();
        dbInsertNode(nk, { cat: node.cat, title: node.title, subtitle: node.sub, url: node.url, detail: node.detail, status: node.status, x: node.x, y: node.y });
      };
      const delN = (id) => {
        document.getElementById(`sn-${id}`)?.remove();
        delete nmap[id];
        delete nels[id];
        edges = edges.filter((edge) => edge.f !== id && edge.t !== id);
        if (conn === id) exitConn(false);
        drawEdges();
        hTip(true);
        dbDeleteNode(id);
      };
      const delP = (id) => {
        document.getElementById(`pl-${id}`)?.remove();
        delete pmap[id];
        delete pels[id];
        planets = planets.filter((planet) => planet.id !== id);
        edges = edges.filter((edge) => edge.f !== id && edge.t !== id);
        if (conn === id) exitConn(false);
        drawEdges();
        hTip(true);
        dbDeleteNode(id);
      };

      const actions = {
        closePep,
        savePep,
        closeHep,
        saveHep,
        closeSep,
        saveSep,
        closeSap,
        addStar,
        closeTep,
        saveTep,
        oHE: () => { openHep(); hCtx(); },
        oCT: () => { if (cxT === 'p') openPep(cxId, 'edit'); else openSep(cxId); hCtx(); },
        oCC: () => { if (cxId) enterConn(cxId === 'home' ? HOME_ID : cxId); hCtx(); },
        oDup: () => { if (cxId && cxT === 's') dupN(cxId); hCtx(); },
        oDel: () => { if (cxT === 'p') delP(cxId); else delN(cxId); hCtx(); },
        doAS: () => { hCtx(); container.querySelector('#sap').style.display = 'block'; },
        doAT: () => { hCtx(); openPep(null, 'add'); },
      };

      const handleAction = (event) => {
        const target = event.target.closest('[data-action]');
        if (!target) return;
        const action = target.getAttribute('data-action');
        if (action === 'etip') {
          const entityId = target.dataset.eid;
          const entityType = target.dataset.etype;
          if (entityType === 'p') openPep(entityId, 'edit');
          else if (entityType === 'h') openHep();
          else if (entityType === 't') openTep(entityId?.replace('timeline-', '') || 'near');
          else openSep(entityId);
          hTip(true);
          return;
        }
        if (action && actions[action]) actions[action]();
      };

      container.addEventListener('click', handleAction);

      const toSVG = (event) => {
        const rect = svg.getBoundingClientRect();
        return viewportToBoard(event.clientX, event.clientY, rect);
      };

      svg.addEventListener('contextmenu', (event) => {
        event.preventDefault();
        event.stopPropagation();
        const star = event.target.closest('.sn');
        const planet = event.target.closest('.pn');
        const home = event.target.closest('.hm');
        if (star) {
          showSCtx(star.getAttribute('data-id'), event.clientX, event.clientY);
          return;
        }
        if (planet) {
          showPCtx(planet.getAttribute('data-pid'), event.clientX, event.clientY);
          return;
        }
        if (home) {
          showHCtx(event.clientX, event.clientY);
          return;
        }
        if (event.target.closest('.del-edge') || event.target.closest('.conn-ctrl') || event.target.closest('.dock-target')) return;
        showCCtx(toSVG(event), event.clientX, event.clientY);
      });

      svg.addEventListener('click', (event) => {
        if (event.target.closest('.sn') || event.target.closest('.pn')) return;
        if (event.target.closest('.hm')) return;
        if (event.target.closest('.del-edge') || event.target.closest('.conn-ctrl') || event.target.closest('.dock-target')) return;
        if (mode === 'connecting') exitConn();
      });

      const handleDocClick = (event) => {
        if (!ctx.contains(event.target)) hCtx();
      };
      document.addEventListener('click', handleDocClick);
      window.addEventListener('resize', syncViewportMode);

      const handleMouseDown = (event) => {
        if (event.target.closest('.conn-ctrl')) return;
        const star = event.target.closest('.sn');
        const planet = event.target.closest('.pn');
        let id;
        let type;
        let entity;
        if (star) {
          id = star.getAttribute('data-id');
          type = 's';
          entity = nmap[id];
        } else if (planet) {
          id = planet.getAttribute('data-pid');
          type = 'p';
          entity = pmap[id];
        }
        if (!entity || !id || !type) return;
        event.preventDefault();
        dragId = id;
        dragType = type;
        hDrag = false;
        const pos = toSVG(event);
        ds.x = pos.x;
        ds.y = pos.y;
        dragOx = pos.x - entity.x;
        dragOy = pos.y - entity.y;
      };
      const handleMouseMove = (event) => {
        if (!dragId) return;
        const pos = toSVG(event);
        const dx = pos.x - ds.x;
        const dy = pos.y - ds.y;
        if (!hDrag && (Math.abs(dx) > 5 || Math.abs(dy) > 5)) {
          hDrag = true;
          hTip(true);
        }
        if (hDrag) {
          const entity = dragType === 'p' ? pmap[dragId] : nmap[dragId];
          if (!entity) return;
          const minX = dragType === 'p' ? entity.r + 8 : 10;
          const maxX = dragType === 'p' ? VW - entity.r - 8 : VW - 10;
          const minY = dragType === 'p' ? entity.r + 8 : 10;
          const maxY = dragType === 'p' ? VH - entity.r - 8 : VH - 18;
          entity.x = Math.max(minX, Math.min(maxX, pos.x - dragOx));
          entity.y = Math.max(minY, Math.min(maxY, pos.y - dragOy));
          document.getElementById(`${dragType === 'p' ? 'pl' : 'sn'}-${dragId}`)?.setAttribute('transform', `translate(${entity.x},${entity.y})`);
          drawEdges();
        }
      };
      const handleMouseUp = () => {
        if (!dragId) return;
        const releasedId = dragId;
        const releasedType = dragType;
        if (hDrag && dragId) {
          const entity = dragType === 'p' ? pmap[dragId] : nmap[dragId];
          if (entity) dbSavePosition(dragId, entity.x, entity.y);
        }
        if (!hDrag && !mode && releasedType === 's') {
          const node = nmap[releasedId];
          if (node?.url) {
            window.open(node.url, '_blank', 'noopener,noreferrer');
          }
        }
        hDrag = false;
        dragId = null;
        dragType = null;
      };

      svg.addEventListener('mousedown', handleMouseDown);
      document.addEventListener('mousemove', handleMouseMove);
      document.addEventListener('mouseup', handleMouseUp);
    };

    const loadBoard = async (user: { id: string }) => {
      const localBoard = readLocalBoard(user.id);

      if (localBoard.hasLocal) {
        renderBoard({
          container: mountEl, boardId: `cached-${user.id}`, userId: user.id,
          initialNodes: localBoard.nodes, initialEdges: localBoard.edges, initialMeta: localBoard.meta,
          db: null, persistenceMode: 'local', storageKey: getLocalStorageKey(user.id), showResetBtn: true,
        });
        showBoard();
        return;
      }

      if (!db) { openLocalBoard(user); return; }

      const { data: boards, error: boardsError } = await db('boards').select('id').eq('user_id', user.id).limit(1);
      if (boardsError) { openLocalBoard(user, 'Cloud sync unavailable. Changes stay in this browser only.'); return; }

      let boardId = boards?.[0]?.id;

      if (!boardId) {
        const { data: newBoard, error } = await db('boards')
          .insert({ user_id: user.id, title: 'Career Strategy Board' })
          .select('id').single();
        if (error || !newBoard) { openLocalBoard(user, 'Cloud board creation failed.'); return; }
        boardId = newBoard.id;
        await db('nodes').insert(CAREER_BOARD_PUBLIC_SEED_NODES.map(n => ({...n, board_id: boardId, user_id: user.id})));
        await db('edges').insert(CAREER_BOARD_PUBLIC_SEED_EDGES.map(e => ({...e, board_id: boardId, user_id: user.id})));
      }

      const [{ data: dbNodes }, { data: dbEdges }] = await Promise.all([
        db('nodes').select('*').eq('board_id', boardId),
        db('edges').select('*').eq('board_id', boardId),
      ]);

      renderBoard({
        container: mountEl, boardId, userId: user.id,
        initialNodes: dbNodes || [], initialEdges: dbEdges || [], initialMeta: localBoard.meta,
        db, persistenceMode: 'remote', storageKey: getLocalStorageKey(user.id), showResetBtn: true,
      });
      showBoard();
    };

    if (hasSupabase && supabase) {
      setState('Loading…');
      try {
        const { data: { session } } = await supabase.auth.getSession();
        if (session?.user) {
          await loadBoard(session.user);
        } else {
          openPublicBoard();
          supabase.auth.onAuthStateChange((event, s) => {
            if (event === 'SIGNED_IN' && s?.user) location.reload();
          });
        }
      } catch {
        openPublicBoard();
      }
    } else {
      openPublicBoard();
    }
  });
</script>
