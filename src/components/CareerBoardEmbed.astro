---
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_KEY ?? '';
const { fullscreen = true } = Astro.props;
---

<section
  class:list={['career-board-app', fullscreen && 'career-board-app--fullscreen']}
  data-career-board-root
  data-supabase-url={supabaseUrl}
  data-supabase-anon-key={supabaseAnonKey}
  data-supabase-db-schema="gekko"
>
  <div class:list={['career-board-shell', fullscreen && 'career-board-shell--fullscreen']}>
    <div class="career-board-shell__state" data-career-board-state>
      Loading board...
    </div>
    <div class="career-board-shell__mount hidden" data-career-board-mount></div>
  </div>
</section>

<script>
  import { getBrowserSupabaseClient } from '../lib/supabase-browser';
  import { CAREER_BOARD_PUBLIC_SEED_NODES, CAREER_BOARD_PUBLIC_SEED_EDGES } from '../lib/career-board-seed';

  const DEFAULT_BOARD_META = {
    homeTitle: 'IT Director',
    homeLine1: '15yr · Enterprise IT · Digital Transformation · Cloud',
    homeLine2: 'Infrastructure · Governance · Global Teams · Budget Owner',
    homeDetail: '15yr Enterprise IT Leadership\nDigital Transformation · Cloud Strategy · GRC\nGlobal Teams · EUR 10M+ Budget Responsibility',
    timelineNear: '3 months',
    timelineMid: '6 months',
    timelineFar: 'Future',
  };

  const boardRoots = document.querySelectorAll('[data-career-board-root]');

  boardRoots.forEach(async (root) => {
    if (!(root instanceof HTMLElement)) return;

    const supabaseUrl = root.dataset.supabaseUrl ?? '';
    const supabaseAnonKey = root.dataset.supabaseAnonKey ?? '';
    const supabaseDbSchema = root.dataset.supabaseDbSchema ?? 'gekko';
    const stateEl = root.querySelector('[data-career-board-state]');
    const mountEl = root.querySelector('[data-career-board-mount]');

    if (!(stateEl instanceof HTMLElement) || !(mountEl instanceof HTMLElement)) return;

    const hasSupabase = Boolean(supabaseUrl && supabaseAnonKey);
    const supabase = hasSupabase ? getBrowserSupabaseClient(supabaseUrl, supabaseAnonKey) : null;
    const db = (hasSupabase && supabase) ? (t: string) => supabase.schema(supabaseDbSchema).from(t) : null;

    const setState = (msg: string, isError = false) => {
      stateEl.textContent = msg;
      stateEl.classList.toggle('career-board-shell__state--error', isError);
    };

    const showBoard = () => {
      stateEl.classList.add('hidden');
      mountEl.classList.remove('hidden');
    };

    const getLocalStorageKey = (userId: string) => `career-board:${userId}`;

    const readLocalBoard = (userId: string) => {
      const fallbackNodes = CAREER_BOARD_PUBLIC_SEED_NODES.map(n => ({...n}));
      const fallbackEdges = CAREER_BOARD_PUBLIC_SEED_EDGES.map(e => ({...e}));
      try {
        const raw = localStorage.getItem(getLocalStorageKey(userId));
        if (!raw) return { hasLocal: false, nodes: fallbackNodes, edges: fallbackEdges, meta: {...DEFAULT_BOARD_META} };
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed?.nodes) || !Array.isArray(parsed?.edges))
          return { hasLocal: false, nodes: fallbackNodes, edges: fallbackEdges, meta: {...DEFAULT_BOARD_META} };
        return { hasLocal: true, nodes: parsed.nodes, edges: parsed.edges, meta: {...DEFAULT_BOARD_META, ...(parsed?.meta ?? {})} };
      } catch {
        return { hasLocal: false, nodes: fallbackNodes, edges: fallbackEdges, meta: {...DEFAULT_BOARD_META} };
      }
    };

    const openLocalBoard = (user: { id: string }, notice?: string) => {
      const localBoard = readLocalBoard(user.id);
      renderBoard({
        container: mountEl, boardId: `local-${user.id}`, userId: user.id,
        initialNodes: localBoard.nodes, initialEdges: localBoard.edges, initialMeta: localBoard.meta,
        db: null, persistenceMode: 'local', storageKey: getLocalStorageKey(user.id), notice, showResetBtn: true,
      });
      showBoard();
    };

    const PUBLIC_STORAGE_KEY = 'career-board:local';

    const openPublicBoard = () => {
      let nodes = CAREER_BOARD_PUBLIC_SEED_NODES.map((node) => ({ ...node }));
      let edges = CAREER_BOARD_PUBLIC_SEED_EDGES.map((edge) => ({ ...edge }));
      let meta = { ...DEFAULT_BOARD_META };

      try {
        const raw = window.localStorage.getItem(PUBLIC_STORAGE_KEY);
        if (raw) {
          const parsed = JSON.parse(raw);
          if (Array.isArray(parsed?.nodes) && Array.isArray(parsed?.edges)) {
            nodes = parsed.nodes;
            edges = parsed.edges;
            meta = { ...DEFAULT_BOARD_META, ...(parsed?.meta || {}) };
          }
        }
      } catch {
        // use defaults
      }

      renderBoard({
        container: mountEl,
        boardId: 'local',
        userId: 'local',
        initialNodes: nodes,
        initialEdges: edges,
        initialMeta: meta,
        db: null,
        persistenceMode: 'local',
        storageKey: PUBLIC_STORAGE_KEY,
        showResetBtn: true,
      });

      showBoard();
    };

    const renderBoard = ({ container, boardId, userId, initialNodes, initialEdges, initialMeta, db, persistenceMode, storageKey, notice, showResetBtn = false }) => {
      const noticeMarkup = notice
        ? `<div class="pnl" style="display:block;"><div style="font-size:12px;color:#e5e7eb;"><strong>Local mode.</strong> ${notice}</div></div>`
        : '';
      const privacyModalMarkup = showResetBtn ? `
<div id="privacy-modal" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(4,8,20,0.90);backdrop-filter:blur(6px);overflow-y:auto;padding:32px 16px;">
  <div id="privacy-panel" style="max-width:520px;margin:0 auto;padding:32px 28px 28px;background:#06091a;border:1px solid rgba(255,255,255,0.07);border-radius:14px;position:relative;cursor:pointer;">
    <button id="close-privacy-btn" style="position:absolute;top:14px;right:14px;background:none;border:none;color:rgba(255,255,255,0.35);font-size:16px;cursor:pointer;line-height:1;padding:4px 8px;border-radius:4px;transition:color .15s;" onmouseover="this.style.color='rgba(255,255,255,0.85)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">✕</button>
    <div style="text-align:center;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,0.06);">
      <img src="/images/goal_gekko.gif" alt="Goal-Gekko" style="width:56px;height:56px;object-fit:contain;display:block;margin:0 auto 12px;">
      <p style="font-size:8px;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:rgba(255,255,255,0.28);margin-bottom:7px;">GOAL-GEKKO</p>
      <p style="font-size:19px;font-weight:300;color:rgba(255,255,255,0.80);letter-spacing:.01em;line-height:1.2;">Welcome to your Future</p>
    </div>
    <p style="font-size:8.5px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-bottom:20px;">Datenschutz</p>
    <div style="border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:14px 16px;margin-bottom:20px;background:rgba(255,255,255,0.03);">
      <p style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.75);margin-bottom:6px;">Kein Tracking. Keine Profile. Keine versteckten Zwecke.</p>
      <p style="font-size:10.5px;line-height:1.7;color:rgba(255,255,255,0.45);">Wir verarbeiten so wenig Daten wie möglich. Was wir erheben, dient ausschließlich dem Betrieb der App — nicht der Analyse, Profilbildung oder Vermarktung. Keine Tracking-Pixel, keine Werbenetzwerke, kein Weiterverkauf. Das gilt für alle Produkte und Webseiten unter Rio Siera.</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px;font-size:10.5px;line-height:1.75;color:rgba(255,255,255,0.48);">
      <div><p style="font-size:8px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:5px;">Kurz gesagt</p><p>Goal-Gekko speichert keine Daten auf einem Server. Alle Boarddaten verlassen Ihr Gerät nicht. Es werden keine Cookies zu Tracking- oder Marketingzwecken eingesetzt.</p></div>
      <div><p style="font-size:8px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:5px;">Lokaler Speicher</p><p>Gespeichert werden ausschließlich Ihre Boardinhalte: Ziele, Zwischenschritte, Verbindungen, Positionen und Labels — im localStorage Ihres Browsers unter dem Schlüssel <code style="font-size:9px;background:rgba(255,255,255,0.06);padding:1px 5px;border-radius:3px;">career-board:local</code>. localStorage ist kein Cookie — die Daten werden nicht automatisch an Server übermittelt.</p></div>
      <div><p style="font-size:8px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:5px;">Löschen</p><p>Alle gespeicherten Daten lassen sich jederzeit über den ↺-Button im Board vollständig löschen. Alternativ direkt über die Browser-Entwicklerwerkzeuge (Anwendung → Lokaler Speicher).</p></div>
      <div><p style="font-size:8px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:5px;">Hosting</p><p>Die App wird bei Vercel bereitgestellt. Vercel verarbeitet technische Verbindungsdaten (IP-Adresse, Zugriffszeitpunkt, Browserinformationen). Rechtsgrundlage: Art. 6 Abs. 1 lit. f DSGVO.</p></div>
      <div><p style="font-size:8px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:5px;">Kein Tracking</p><p>Es werden keine Analyse-Dienste eingesetzt. Keine Nutzerprofile, keine Verhaltensdaten, keine Drittanbieter-Scripts.</p></div>
      <div><p style="font-size:8px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.2);margin-bottom:5px;">Verantwortlicher</p><p>Alessandro Cancemi · Hohenzollernring 1-3 · 50672 Köln · <a href="mailto:${atob('aW5mb0BjYW5jZW1pLmRl')}" style="color:inherit;">info&#64;cancemi&#46;de</a></p></div>
    </div>
    <p style="font-size:8.5px;color:rgba(255,255,255,0.18);margin-top:22px;">Stand: April 2026</p>
  </div>
</div>` : '';

      const fixedControlsMarkup = showResetBtn ? `
