  <button id="clear-btn" title="Board leeren" style="background:none;border:1px solid rgba(255,255,255,0.12);border-radius:50%;width:29px;height:29px;cursor:pointer;color:rgba(255,255,255,0.30);font-size:14px;line-height:1;padding:0;opacity:0.7;transition:opacity .2s,color .2s,border-color .2s;" onmouseover="this.style.opacity='1';this.style.color='rgba(255,255,255,0.72)';this.style.borderColor='rgba(255,255,255,0.32)'" onmouseout="this.style.opacity='0.7';this.style.color='rgba(255,255,255,0.30)';this.style.borderColor='rgba(255,255,255,0.12)'">⊘</button>
  <button id="reset-btn" title="Board zurücksetzen" style="background:none;border:1px solid rgba(255,255,255,0.12);border-radius:50%;width:29px;height:29px;cursor:pointer;color:rgba(255,255,255,0.30);font-size:16px;line-height:1;padding:0;opacity:0.7;transition:opacity .2s,color .2s,border-color .2s;" onmouseover="this.style.opacity='1';this.style.color='rgba(255,255,255,0.72)';this.style.borderColor='rgba(255,255,255,0.32)'" onmouseout="this.style.opacity='0.7';this.style.color='rgba(255,255,255,0.30)';this.style.borderColor='rgba(255,255,255,0.12)'">↺</button>
